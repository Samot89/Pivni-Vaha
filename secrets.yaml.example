# Example secrets file for ESPHome
# Copy this file to secrets.yaml and fill in your actual values
# The secrets.yaml file is gitignored for security

# Wi-Fi Configuration
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# Fallback AP (when Wi-Fi fails)
# ap_password: "YourFallbackAPPassword"

# API Encryption Key (generate with: esphome)
# You can generate a new key by running:
# python3 -c "import secrets; print(secrets.token_hex(32))"
# api_encryption_key: "your-32-byte-hex-encryption-key"

# OTA Password
# ota_password: "your-ota-password"
